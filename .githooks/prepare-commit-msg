#!/bin/sh
# prepare-commit-msg: auto-generate release message when version changes
#
# $1 = path to commit message file
# $2 = source (message/template/merge/squash/commit)

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# Only auto-fill when no -m flag was used
if [ "$COMMIT_SOURCE" = "message" ]; then
  exit 0
fi

# Check if package.json version changed in staged area
VERSION_CHANGE=$(git diff --cached -- package.json | grep '"version"' | grep '^[+-]')
if [ -z "$VERSION_CHANGE" ]; then
  exit 0
fi

# Extract new version from staged package.json
NEW_VERSION=$(git show :package.json | node -e "process.stdin.resume(); let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>console.log(JSON.parse(d).version))")

# Read current message content (if any exists)
EXISTING_MSG=$(cat "$COMMIT_MSG_FILE" 2>/dev/null)

echo "release: v${NEW_VERSION}" > "$COMMIT_MSG_FILE"
if [ -n "$EXISTING_MSG" ]; then
  echo "" >> "$COMMIT_MSG_FILE"
  echo "$EXISTING_MSG" >> "$COMMIT_MSG_FILE"
fi
